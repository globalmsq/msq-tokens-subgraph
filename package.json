{
  "name": "msq-tokens-subgraph",
  "version": "0.1.0",
  "description": "The Graph subgraph for MSQ tokens on Polygon",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "clean": "rm -rf build/ generated/ src/types/",
    "validate": "graph validate",
    "create-local": "graph create --node http://localhost:8020/ msq-tokens-subgraph",
