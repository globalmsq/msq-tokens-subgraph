    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 msq-tokens-subgraph",
    "test": "graph test"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "^0.71.1",
    "@graphprotocol/graph-ts": "^0.35.1"
  },
  "devDependencies": {
    "matchstick-as": "^0.6.0"
  }
}
